{
  "name": "@floo-one/nuxt-feedback",
  "version": "0.2.4",
  "description": "Drop-in in-app feedback dialog for Nuxt 4 — bugs and ideas to GitHub Issues, with a server-side submit hook.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/floo-one/nuxt-feedback.git"
  },
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "pnpm run dev:prepare && nuxt dev dashboard",
    "dev:build": "nuxt build dashboard",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare dashboard",
    "release": "pnpm run lint && pnpm run test && pnpm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd dashboard && vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.8",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@nuxt/ui": ">=4.0.0"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.8",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxt/ui": "^4.9.0",
    "@types/node": "latest",
    "changelogen": "^0.6.2",
    "eslint": "^10.4.1",
    "happy-dom": "^20.10.6",
    "nuxt": "^4.4.8",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.3"
  }
}
